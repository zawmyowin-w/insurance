# Copy this file to ".env" in the frontend/ folder and fill in real values.
# All variables are optional — the app runs without them, but the
# email (OTP / password reset) feature will be disabled until set.

VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_VERIFY_TEMPLATE=
VITE_EMAILJS_RESET_TEMPLATE=
