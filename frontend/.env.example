# ─────────────────────────────────────────────────────────────────────
# Frontend Environment Variables — Local Development
# ─────────────────────────────────────────────────────────────────────
# Copy this file to ".env" and fill in your values.
# All variables are OPTIONAL.
# Without them the app works normally but email OTP / password
# reset emails will not be sent (a demo code is shown in the
# browser console instead for development purposes).
# ─────────────────────────────────────────────────────────────────────

# ── EmailJS (for OTP and password reset emails) ──────────────────────
# Sign up at https://www.emailjs.com to get these values.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_VERIFY_TEMPLATE=
VITE_EMAILJS_RESET_TEMPLATE=
