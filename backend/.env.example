# Copy this file to ".env" (or set these as real environment variables on
# your machine / in your IDE run configuration) before running the backend
# locally. Everything has a safe local default in application.properties,
# so this file is only needed if you want to override something.

# MySQL root password (leave empty if your local MySQL root user has no password)
DB_PASSWORD=

# JWT signing secret — use a long random string in real deployments
JWT_SECRET=LocalDevInsurancePortalSecretKey2024VeryLongSecureKeyForHMACSHA256

# Default admin account created on first startup
ADMIN_EMAIL=admin@dicp.com.mm
ADMIN_PASSWORD=Admin@123

# Comma-separated list of frontend origins allowed to call the API
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5000
