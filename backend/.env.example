# ─────────────────────────────────────────────────────────────────────
# Backend Environment Variables — Local Development
# ─────────────────────────────────────────────────────────────────────
# Copy this file to ".env" and fill in your values.
# The app has built-in defaults for every variable so it runs
# out-of-the-box without any configuration — just set DB_PASSWORD
# if your MySQL root account has a password.
# ─────────────────────────────────────────────────────────────────────

# ── MySQL Database ───────────────────────────────────────────────────
# Password for the MySQL root account on localhost.
# Leave blank if your local MySQL has no root password.
DB_PASSWORD=

# ── JWT Secret ───────────────────────────────────────────────────────
# Used to sign and verify JWT tokens. Change this to a long random
# string in any shared environment.
JWT_SECRET=LocalDevInsurancePortalSecretKey2024VeryLongSecureKeyForHMACSHA256

# ── Admin Bootstrap Account ──────────────────────────────────────────
# Created automatically on first run if no admin exists yet.
# You can change the credentials here before the first run.
ADMIN_EMAIL=admin@dicp.com.mm
ADMIN_PASSWORD=Admin@123
