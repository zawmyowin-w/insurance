# ─────────────────────────────────────────────────────────────────────
# Backend Environment Variables — Local Development
# ─────────────────────────────────────────────────────────────────────
# Copy this file to ".env" and fill in your values.
#   cp backend/.env.example backend/.env
#
# start-backend.sh loads this file automatically — no need to
# manually export variables before running.
# ─────────────────────────────────────────────────────────────────────

# ── MySQL connection ──────────────────────────────────────────────────
# Defaults shown below — only change what differs on your machine.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=insurance_portal
DB_USER=root
DB_PASSWORD=

# ── JWT signing key ───────────────────────────────────────────────────
# Optional for local dev — a safe default is used if left empty.
JWT_SECRET=

# ── AI features (Auto Check + Insurance AI Assistant) ────────────────
# Get your key at https://console.x.ai
XAI_API_KEY=

# ── Admin account ─────────────────────────────────────────────────────
# Default credentials used on first run if not set.
ADMIN_EMAIL=admin@dicp.com.mm
ADMIN_PASSWORD=Admin@123

# ── File storage ──────────────────────────────────────────────────────
# Where uploaded documents are stored. Default: backend/uploads/
# FILE_STORAGE_DIR=./uploads
