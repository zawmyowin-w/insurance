# ─────────────────────────────────────────────────────────────────────
# Backend Environment Variables — Local Development
# ─────────────────────────────────────────────────────────────────────
# Copy this file to ".env" and fill in your values:
#   cp backend/.env.example backend/.env
#
# Every variable has a safe built-in default, so the app works
# out of the box. Only DB_PASSWORD is likely to need changing.
# ─────────────────────────────────────────────────────────────────────

# ── MySQL Database ───────────────────────────────────────────────────
# Password for the MySQL root account on localhost.
# Leave blank if your local MySQL has no root password.
DB_PASSWORD=

# ── JWT Secret ───────────────────────────────────────────────────────
# Used to sign and verify JWT tokens. Change in any shared environment.
JWT_SECRET=LocalDevInsurancePortalSecretKey2024VeryLongSecureKeyForHMACSHA256

# ── Admin Bootstrap Account ──────────────────────────────────────────
# Created automatically on first run if no admin exists yet.
ADMIN_EMAIL=admin@dicp.com.mm
ADMIN_PASSWORD=Admin@123

# ── AI Chat (optional) ───────────────────────────────────────────────
# Powers the "Ask AI" chat widget on the home page using xAI Grok.
# Get your key at: https://console.x.ai
# If not set, the chat falls back to a rule-based response engine.
XAI_API_KEY=
