modules = ["nodejs-20", "java-graalvm22.3", "web", "bash", "python-base-3.13"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Backend"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && bash start-backend.sh"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[[ports]]
localPort = 8080
externalPort = 8080

[userenv]

[userenv.shared]
VITE_GOOGLE_CLIENT_ID = "732524451408-48i8ts7a6mfl194nc9rqoebjnnpnsggg.apps.googleusercontent.com"
CORS_ALLOWED_ORIGINS = "http://localhost:5000,http://localhost:5173,https://4cd422cb-c41f-4cd8-b70e-4b58831a687c-00-3g04sfws5nf0m.sisko.replit.dev"
